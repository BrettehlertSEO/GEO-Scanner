# GEO-Scanner Configuration
# Copy this file to .env and fill in your values.

# OpenAI API key for LLM-powered analysis
OPENAI_API_KEY=sk-...

# Brand to monitor (default: Rocket Money)
BRAND_NAME=Rocket Money

# Additional brand aliases / alternate names (comma-separated)
BRAND_ALIASES=RocketMoney,Rocket Money app

# Google Alerts RSS feed URLs (comma-separated)
# Set up alerts at https://www.google.com/alerts, then copy the RSS feed URLs.
# If left empty, GEO-Scanner will auto-generate Google News RSS feeds from your brand terms.
GOOGLE_ALERTS_FEED_URLS=

# How many results to process per scan
MAX_RESULTS_PER_QUERY=20

# How often to scan in watch mode (hours). Default: 12 (twice daily)
SCAN_INTERVAL_HOURS=12

# SQLite database path
DATABASE_PATH=geo_scanner.db

# OpenAI model to use for analysis
OPENAI_MODEL=gpt-4o-mini

# Request timeout in seconds
REQUEST_TIMEOUT=30

# User-Agent string for crawling
USER_AGENT=GEO-Scanner/0.1 (+https://github.com/your-org/geo-scanner)
